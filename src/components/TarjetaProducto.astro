---
// src/components/TarjetaProducto.astro
const { nombre, categoria, precio, imagen, descripcion, stock, slug, whatsappUrl } = Astro.props;

// Evaluamos si hay existencias disponibles
const tieneStock = stock > 0;
---

<div class="border border-gray-200/70 rounded-xl overflow-hidden bg-white shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
  <div>
    <!-- Contenedor de la Imagen con enlace a la página interna -->
    <a href={`/productos/${slug}`} class="block aspect-square bg-gray-50 relative overflow-hidden group">
      <img 
        src={imagen} 
        alt={nombre} 
        class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
      <!-- Etiqueta con el fondo Morado YDATECH -->
      <span class="absolute top-3 left-3 bg-[#5c3aff] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm">
        {categoria}
      </span>

      <!-- ETIQUETA DE STOCK DINÁMICA -->
      <span class={`absolute top-3 right-3 text-[9px] font-bold px-2 py-0.5 rounded-md shadow-sm backdrop-blur-sm ${
        tieneStock 
          ? 'bg-emerald-50/90 text-emerald-700 border border-emerald-200/50' 
          : 'bg-rose-50/90 text-rose-700 border border-rose-200/50'
      }`}>
        {tieneStock ? '● Disponible' : 'Agotado'}
      </span>
    </a>

    <!-- Datos del producto -->
    <div class="p-4">
      <a href={`/productos/${slug}`} class="block group">
        <h3 class="text-base font-bold text-gray-900 line-clamp-1 group-hover:text-[#5c3aff] transition-colors">{nombre}</h3>
      </a>
      <p class="mt-1 text-xs text-gray-500 line-clamp-2 h-8">{descripcion}</p>
    </div>
  </div>
  
  <!-- Precios y Botón de Acción Directo Condicional -->
  <div class="p-4 pt-0">
    <div class="flex items-center justify-between border-t border-gray-100 pt-3 my-3">
      <span class="text-[11px] font-medium text-gray-400 uppercase tracking-wider">Precio Ref.</span>
      <span class="text-lg font-black text-gray-900">${precio.toFixed(2)}</span>
    </div>
    
    <!-- Enlace hacia WhatsApp (Cambia de color y texto si está agotado) -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`w-full flex items-center justify-center gap-2 font-semibold text-xs py-3 px-4 rounded-lg transition-colors shadow-sm active:scale-[0.98] ${
        tieneStock 
          ? 'bg-[#5c3aff] hover:bg-[#4b2ee0] text-white shadow-indigo-100' 
          : 'bg-gray-100 hover:bg-gray-200 text-gray-500 border border-gray-200'
      }`}
    >
      {tieneStock ? (
        <svg xmlns="http://w3.org" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6-.097.382-.41 1.43-.544 1.88-.13.432.189.456.408.345 1.154-.585 2.138-.434 2.138-.434A7.5 7.5 0 0 0 8 15"/>
        </svg>
        <span>Consultar Agente</span>
      ) : (
        <svg xmlns="http://w3.org" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <span>Consultar Próximo Ingreso</span>
      )}
    </a>
  </div>
</div>
